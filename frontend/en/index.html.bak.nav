</head>
<body>

    <div class="decor-line line-left"></div>
    <div class="decor-line line-right"></div>

    <nav class="navbar" id="navbar">
        <ul class="nav-left">
            <li><a href="damai.html" class="nav-link">Damai</a></li>
            <li><a href="culto.html" class="nav-link">Culto</a></li>
            <li><a href="../fiordacqua.html" class="nav-link">Fior d'Acqua</a></li>
        </ul>
        
        <a href="index.html" class="logo-link">
            <img src="../assets/logos/logo-playaluna.webp" alt="Playa Luna Varcaturo" class="logo">
        </a>

        <ul class="nav-right">
            <li><a href="beach.html" class="nav-link">Beach</a></li>
            <li><a href="ristorante.html" class="nav-link">Restaurant</a></li>
            <li><a href="eventi.html" class="nav-link">Events</a></li>
            <li><a href="contatti.html" class="nav-link">Contact</a></li>
            <li class="lang-switcher">
                <a href="#" class="active">EN</a> | <a href="../index.html">IT</a>
            </li>
        </ul>
        <div class="hamburger" id="hamburger">
            <span></span>
            <span></span>
            <span></span>
        </div>
    </nav>



    <header class="hero">
        <video autoplay loop muted playsinline style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0.85; z-index: 1;">
            <source src="../assets/videos/hero_home.mp4" type="video/mp4">
        </video>
        <div class="hero-content">
            <span class="hero-tagline reveal">Exclusivity Has a New Horizon</span>
            <h1 class="hero-title reveal">Experience the Emotion <br>of the Coast</h1>
            <div class="reveal">
                <a href="#triad" class="btn-luxury">Discover More</a>
            </div>
        </div>
    </header>

    <section class="triad-section" id="triad">
        <div style="text-align: center; margin-bottom: 5rem;" class="reveal">
            <span style="text-transform: uppercase; letter-spacing: 5px; color: var(--gold); font-size: 0.8rem; font-weight: 600;">Three souls, one heart</span>
        </div>
        <div class="triad-grid">
            <a href="ristorante.html" class="triad-card reveal">
                <img src="../assets/images/card-ristorante-home.webp" srcset="../assets/images/mobile-card-ristorante-home.webp 800w, ../assets/images/card-ristorante-home.webp 1200w" sizes="(max-width: 800px) 800px, 1200px" alt="Restaurant Playa Luna" loading="lazy">
                <div class="card-content">
                    <span class="card-label">Gourmet Experience</span>
                    <h3 class="card-title">The Restaurant</h3>
                </div>
            </a>
            <a href="beach.html" class="triad-card reveal">
                <img src="../assets/images/card-beach-home.webp" srcset="../assets/images/mobile-card-beach-home.webp 800w, ../assets/images/card-beach-home.webp 1200w" sizes="(max-width: 800px) 800px, 1200px" alt="Beach Club Playa Luna" loading="lazy">
                <div class="card-content">
                    <span class="card-label">Pure Relaxation</span>
                    <h3 class="card-title">The Beach</h3>
                </div>
            </a>
            <a href="eventi.html" class="triad-card reveal">
                <img src="../assets/images/card-eventi-home.webp" srcset="../assets/images/mobile-card-eventi-home.webp 800w, ../assets/images/card-eventi-home.webp 1200w" sizes="(max-width: 800px) 800px, 1200px" alt="Events Privati" loading="lazy">
                <div class="card-content">
                    <span class="card-label">Private Celebrations</span>
                    <h3 class="card-title">The Events</h3>
                </div>
            </a>
        </div>
    </section>

    <section class="network-section">
        <h2 class="reveal">A Network of Excellence</h2>
        <div class="network-grid reveal">
            <a href="https://varcadoro.com/" target="_blank" class="network-card">
                <img src="../assets/logos/logo-varcadoro.webp" alt="Varca d'Oro">
            </a>
            <div class="network-card">
                <img src="../assets/logos/logo-culto.webp" alt="Culto">
            </div>
            <div class="network-card">
                <img src="../assets/logos/logo-damai.webp" alt="Damai">
            </div>
            <div class="network-card">
                <img src="../assets/logos/logo-naturale.webp" alt="Naturale">
            </div>
            <div class="network-card">
                <img src="../assets/logos/logo-key.webp" alt="Key Beach">
            </div>
            <div class="network-card">
                <img src="../assets/logos/logo-fiordacqua.webp" alt="Fior d'Acqua">
            </div>
            <div class="network-card">
                <img src="../assets/logos/logo-lacostiera.webp" alt="La Costiera">
            </div>
        </div>
    </section>

    <section class="social-feed">
        <div class="social-header reveal">
            <span>Follow the lifestyle</span>
            <h2><svg class="ig-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.7" fill="currentColor" stroke="none"/></svg><a href="https://www.instagram.com/lidoplayaluna/" target="_blank">@playalunaofficial</a></h2>
        </div>
        <div class="instagram-grid reveal">
            <a href="https://www.instagram.com/lidoplayaluna/" target="_blank" class="insta-post" aria-label="Instagram Post 1">
                <img src="../assets/images/social/mobile-lido-1.webp" alt="Instagram Post" loading="lazy">
                <div class="insta-overlay"><p>View on Instagram</p></div>
            </a>
            <a href="https://www.instagram.com/lidoplayaluna/" target="_blank" class="insta-post" aria-label="Instagram Post 2">
