    <link rel="canonical" href="https://www.playaluna.it/en/">
    
    <!-- Hreflang Tags (International SEO) -->
    <link rel="alternate" hreflang="it" href="https://www.playaluna.it/">
    <link rel="alternate" hreflang="en" href="https://www.playaluna.it/en/">
    <link rel="alternate" hreflang="x-default" href="https://www.playaluna.it/">
    
    <!-- Open Graph / Social Media -->
    <meta property="og:title" content="Playa Luna | Beach, Restaurant & Events - Varcaturo, Naples">
    <meta property="og:description" content="Discover Playa Luna in Varcaturo: an exclusive experience featuring fine seafood dining, beach relaxation, and unforgettable sunset parties. Your luxury coastal retreat.">
    <meta property="og:url" content="https://www.playaluna.it/en/">
    <meta property="og:type" content="website">
    <meta property="og:image" content="https://www.playaluna.it/assets/images/hero-home.webp">
    <meta property="og:site_name" content="Playa Luna">
    
    <!-- Twitter Cards -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="Playa Luna | Beach, Restaurant & Events - Varcaturo, Naples">
    <meta name="twitter:description" content="Discover Playa Luna in Varcaturo: an exclusive experience featuring fine seafood dining, beach relaxation, and unforgettable sunset parties. Your luxury coastal retreat.">
    <meta name="twitter:image" content="https://www.playaluna.it/assets/images/hero-home.webp">
    
    
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet">
    
    <link rel="icon" type="image/png" href="../assets/favicon.webp">
    <link rel="apple-touch-icon" href="../assets/favicon.webp">
    <meta name="theme-color" content="#1A1208">

    <style>
        :root {
            --sand: #E0D4BB;
            --gold: #C9A84C;
            --off-white: #F9F7F2;
            --white: #FFFFFF;
            --text-dark: #1A1208;
            --text-light: #666059;
            --duration-slow: 0.8s;
            --ease-out-expo: cubic-bezier(0.19, 1, 0.22, 1);
            --slide-padding: 8vw;
        }

        /* Decorazioni Estetiche */
        .decor-line {
            position: fixed; top: 0; width: 1px; height: 100vh;
            background: linear-gradient(to bottom, transparent, var(--gold), transparent);
            opacity: 0.1; z-index: 1002; pointer-events: none;
        }
        .line-left { left: 4vw; }
        .line-right { right: 4vw; }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { 
            background-color: var(--off-white); 
            color: var(--text-dark); 
            font-family: 'Montserrat', sans-serif; 
            overflow-x: hidden;
            line-height: 1.6;
        }

        h1, h2, h3, h4 { font-family: 'Playfair Display', serif; font-weight: 400; }

        /* Navbar Custom */
        .navbar {
            position: fixed; top: 0; left: 0; width: 100%;
            padding: 2rem var(--slide-padding);
            display: grid; grid-template-columns: 1fr auto 1fr;
            align-items: center; z-index: 1000;
            transition: all 0.5s var(--ease-out-expo);
        }
        .navbar.scrolled {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(15px);
            padding: 1.2rem var(--slide-padding);
            box-shadow: 0 10px 40px rgba(0,0,0,0.05);
        }

        .lang-switcher { font-size: 0.7rem; letter-spacing: 2px; text-transform: uppercase; margin-left: 1rem; }
        .lang-switcher a { text-decoration: none; color: var(--white); opacity: 0.6; transition: 0.3s; }
        .lang-switcher a.active { opacity: 1; font-weight: 600; }
        .navbar.scrolled .lang-switcher a { color: var(--text-dark); }

        .nav-left { display: flex; justify-content: flex-start; gap: 2rem; list-style: none; }
        .nav-right { display: flex; justify-content: flex-end; gap: 2.5rem; list-style: none; align-items: center; }
        .nav-link {
            text-decoration: none; color: var(--white);
            font-size: 0.75rem; font-weight: 500;
            text-transform: uppercase; letter-spacing: 2px;
            transition: color 0.3s;
            text-shadow: 0 1px 6px rgba(0,0,0,0.4);
        }
        .navbar.scrolled .nav-link { color: var(--text-dark); }
        .nav-link:hover { color: var(--gold); }

        .logo { 
            height: 180px !important; width: auto !important; 
            object-fit: contain; transition: all 0.5s;
            filter: brightness(0) invert(1);
        }
        .navbar.scrolled .logo { height: 120px !important; filter: none; }

        /* Hero Ken Burns */
        .hero {
            height: 100vh; width: 100%; position: relative;
            overflow: hidden; display: flex; align-items: center;
            justify-content: center; text-align: center;
        }
        .hero-bg {
            position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            background-size: cover; background-position: center;
            animation: kenburns 20s infinite alternate;
            z-index: 1;
        }
        @keyframes kenburns {
            0% { transform: scale(1) translate(0, 0); }
            100% { transform: scale(1.15) translate(-1%, -1%); }
        }
        .hero::before {
            content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            background: 
                linear-gradient(to bottom, 
                    rgba(26,18,8,0.55) 0%,
                    rgba(26,18,8,0.15) 14%,
                    rgba(255,255,255,0.05) 35%,
                    rgba(255,255,255,0.35) 65%,
                    var(--white) 100%);
            z-index: 2;
        }
        .hero-content { 
            position: relative; z-index: 10; color: #1A1208; max-width: 900px; padding: 2.5rem 3rem;
            background: rgba(255,255,255,0.45);
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            border-radius: 4px;
            border: 1px solid rgba(255,255,255,0.7);
        }
        .hero-tagline { 
            display: block; font-size: 0.9rem; text-transform: uppercase; 
            letter-spacing: 6px; margin-bottom: 1.5rem; opacity: 1 !important;
            color: #1A1208 !important;
            text-shadow: 0 1px 8px rgba(255,255,255,0.9);
        }
        .hero-title { 
            font-size: clamp(3rem, 8vw, 6rem); line-height: 1.1; 
            margin-bottom: 3rem;
            color: #1A1208 !important;
            text-shadow: 0 2px 16px rgba(255,255,255,0.8), 0 1px 4px rgba(255,255,255,0.6);
        }

        /* Triad Section */
        .triad-section { padding: 10rem var(--slide-padding); background: var(--white); }
        .triad-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2.5rem; }
        .triad-card {
            position: relative; height: 75vh; overflow: hidden;
            display: flex; align-items: flex-end; padding: 3.5rem;
            text-decoration: none; color: var(--white);
        }
        .triad-card img {
            position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            object-fit: cover; transition: transform 1.5s var(--ease-out-expo);
            z-index: 1;
        }
        .triad-card:hover img { transform: scale(1.1); }
        .triad-card::after {
            content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            background: linear-gradient(to bottom, transparent 40%, rgba(0,0,0,0.8));
            z-index: 2;
        }
        .card-content { position: relative; z-index: 10; }
        .card-label { 
            display: inline-block;
            background: #1A1208;
            color: var(--gold);
            padding: 5px 15px;
            border-radius: 50px;
            font-size: 0.65rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-bottom: 0.8rem;
            font-weight: 600;
        }
        .card-title { font-size: 2.8rem; line-height: 1.2; color: #fff; margin: 0; }

        /* Network Glassmorphism Gallery */
        .network-section { padding: 10rem 0; background: #fdfaf5; text-align: center; border-top: 1px solid rgba(0,0,0,0.05); }
        .network-section h2 { 
            font-size: clamp(3rem, 8vw, 4.5rem); 
            margin-bottom: 7rem; 
            letter-spacing: 12px; 
            color: var(--text-dark); 
            font-family: 'Playfair Display', serif;
            text-transform: uppercase;
        }
        .network-grid { 
            display: flex; flex-wrap: wrap; justify-content: center; 
            gap: 2rem; max-width: 1400px; margin: 0 auto; padding: 0 5vw;
        }
        .network-card {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 1);
            border-radius: 40px; padding: 4rem 3rem;
            display: flex; align-items: center; justify-content: center;
            transition: all 0.7s var(--ease-out-expo);
            width: 320px; height: 200px;
            box-shadow: 0 15px 50px rgba(0,0,0,0.03);
            text-decoration: none;
        }
        .network-card img { 
            max-width: 100%; max-height: 100px; object-fit: contain; 
            filter: grayscale(1) opacity(0.7); transition: 0.6s; 
        }
        .network-card:hover {
            transform: translateY(-15px) scale(1.05);
            background: rgba(255, 255, 255, 0.95);
            box-shadow: 0 30px 60px rgba(0,0,0,0.08);
            border-color: var(--gold);
        }
        .network-card:hover img { filter: grayscale(0) opacity(1); }

        /* --- 2. MOBILE HAMBURGER MENU --- */
        .hamburger { display: none; cursor: pointer; z-index: 10001; background: none; border: none; padding: 10px; position: relative; flex-shrink: 0; }
        .hamburger span { display: block; width: 26px; height: 2px; margin: 6px 0; background-color: #fff; transition: all 0.35s ease; border-radius: 2px; }
        .navbar.scrolled .hamburger span, .navbar:not(.hero-nav) .hamburger span { background-color: #1A1208; }
        .mobile-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: #1A1208; z-index: 9998; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 0.5rem; transform: translateX(100%); visibility: hidden; transition: transform 0.45s cubic-bezier(0.77,0.2,0.05,1.0), visibility 0.45s; }
        .mobile-overlay.active { transform: translateX(0); visibility: visible; }
        .mobile-nav-links { list-style: none; text-align: center; padding: 0; margin: 0; width: 100%; }
        .mobile-nav-links li { margin: 1.2rem 0; }
        .mobile-nav-links a { color: #F9F7F2; text-decoration: none; font-size: clamp(1.4rem, 7vw, 2.2rem); text-transform: uppercase; letter-spacing: 5px; font-family: 'Playfair Display', serif; transition: color 0.3s, letter-spacing 0.3s; display: inline-block; }
        .mobile-nav-links a:hover { color: #C9A84C; letter-spacing: 7px; }
        .mobile-lang { margin-top: 2.5rem; font-size: 0.75rem; letter-spacing: 4px; color: rgba(255,255,255,0.35); text-transform: uppercase; }
        .mobile-lang a { color: rgba(255,255,255,0.6); text-decoration: none; margin: 0 0.5rem; }
        .mobile-lang a:hover { color: #C9A84C; }
        .hamburger.active span:nth-child(1) { transform: rotate(-45deg) translate(-6px, 7px); }
        .hamburger.active span:nth-child(2) { opacity: 0; transform: translateX(-10px); }
        .hamburger.active span:nth-child(3) { transform: rotate(45deg) translate(-6px, -7px); }
        
        @media screen and (max-width: 1024px) {
            .hamburger { 
                display: block !important; 
                background: rgba(255,255,255,0.1) !important;
                border: 1px solid rgba(255,255,255,0.3) !important;
                border-radius: 50% !important;
                padding: 10px !important;
                backdrop-filter: blur(10px) !important;
            }
            .navbar .nav-left, .navbar .nav-right, .navbar .nav-links, .navbar .lang-switcher { display: none !important; }
            .navbar { 
                display: flex !important; 
                flex-direction: row !important;
                justify-content: space-between !important; 
                align-items: center !important; 
                padding: 0.8rem 5vw !important; 
                width: 100% !important;
                left: 0 !important;
                right: 0 !important;
                background: transparent;
            }
            .navbar.scrolled { background: rgba(255,255,255,0.98) !important; }
            .navbar.scrolled .hamburger { background: rgba(26,18,8,0.05) !important; border-color: rgba(0,0,0,0.1) !important; }
            .navbar .logo { height: 90px !important; width: auto !important; }
            .navbar .logo-link { flex: 0 0 auto; }
            
            .hero { height: auto !important; min-height: 80vh !important; display: flex !important; flex-direction: column !important; justify-content: center !important; padding: 140px 5vw 60px !important; }
            .hero-content { 
                margin-top: 0 !important; 
                background: rgba(255,255,255,0.5) !important;
                backdrop-filter: blur(8px) !important;
                -webkit-backdrop-filter: blur(8px) !important;
                border: 1px solid rgba(255,255,255,0.65) !important;
                padding: 1.8rem 1.5rem !important;
                width: 100% !important;
                box-shadow: none !important;
                text-align: center;
                border-radius: 2px !important;
            }
            .hero-title { font-size: clamp(2rem, 9vw, 3.5rem) !important; line-height: 1.1 !important; color: #1A1208 !important; text-shadow: 0 1px 10px rgba(255,255,255,0.7) !important; }
            .hero-tagline { font-size: 0.7rem !important; letter-spacing: 2px !important; color: #1A1208 !important; opacity: 1 !important; text-shadow: 0 1px 6px rgba(255,255,255,0.8) !important; }
            .btn-luxury { padding: 1.1rem 2.8rem !important; font-size: 0.7rem !important; background: transparent !important; border: 1.5px solid #1A1208 !important; color: #1A1208 !important; text-transform: uppercase; letter-spacing: 2px; }
            
            .triad-grid { grid-template-columns: 1fr !important; }
            .triad-card { height: 55vh !important; }
            .card-title { font-size: 2.2rem !important; }

            .network-grid { gap: 1rem !important; }
            .network-card { width: calc(50% - 1rem) !important; height: 120px !important; padding: 1.5rem !important; border-radius: 20px !important; }
            .network-card img { max-height: 40px !important; }

            .social-header { margin-bottom: 1.5rem !important; padding: 0 5vw !important; }
            .social-header h2 { 
                font-size: clamp(0.95rem, 4.5vw, 1.4rem) !important; 
                line-height: 1.2 !important; 
                letter-spacing: 0.5px !important; 
                text-transform: lowercase !important;
                white-space: nowrap !important;
                display: flex !important;
                align-items: center !important;
                justify-content: center !important;
                gap: 0.4em !important;
                max-width: 100% !important;
            }
            .ig-icon { width: 1.1em; height: 1.1em; flex-shrink: 0; }
            .social-header span { font-size: 0.6rem !important; letter-spacing: 2px !important; }
            .social-header h2 a { color: var(--gold) !important; text-decoration: none; border-bottom: 1px solid rgba(201,168,76,0.2); }
            
            .instagram-grid { 
                display: flex !important;
                overflow-x: auto;
                -webkit-overflow-scrolling: touch;
                scroll-snap-type: x mandatory;
                gap: 1rem;
                padding: 0 10vw 2rem;
                scrollbar-width: none;
            }
            .instagram-grid::-webkit-scrollbar { display: none; }
            .insta-post { 
                width: 80vw !important; 
                max-width: 320px;
                height: 80vw !important;
                max-height: 320px;
                flex-shrink: 0;
                scroll-snap-align: center;
            }
        }
        @media (max-width: 480px) {
            .triad-card { height: 45vh !important; }
            .hero-title { font-size: 2.2rem !important; letter-spacing: 3px; }
        }
    </style>

