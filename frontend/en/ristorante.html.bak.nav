        </ul>

        <a href="index.html" class="logo-link"><img src="../assets/logos/logo-playaluna.webp" alt="Playa Luna" class="logo"></a>

        <ul class="nav-right">
            <li><a href="beach.html" class="nav-link">Beach</a></li>
            <li><a href="ristorante.html" class="nav-link" style="color: var(--gold) !important;">Restaurant</a></li>
            <li><a href="eventi.html" class="nav-link">Events</a></li>
            <li><a href="contatti.html" class="nav-link">Contact</a></li>
            <li class="lang-switcher">
                <a href="#" class="active">EN</a> | <a href="../ristorante.html">IT</a>
            </li>
        </ul>
        <div class="hamburger" id="hamburger">
            <span></span>
            <span></span>
            <span></span>
        </div>
    </nav>



    <header class="hero">
        <picture class="hero-bg">
            <source srcset="../assets/images/mobile-hero-ristorante.webp?v=1.2" media="(max-width: 800px)" type="image/webp">
            <img src="../assets/images/hero-ristorante.webp?v=1.2" alt="Restaurant Playa Luna" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; z-index: 1;">
        </picture>
        <div class="hero-content">
            <span class="badge-label">Gourmet Experience</span>
            <h1 class="hero-title" style="color: var(--white) !important; text-shadow: 0 2px 20px rgba(0,0,0,0.2) !important;">High Quality Cuisine</h1>
        </div>
    </header>

    <section class="signature-section reveal">
        <span class="signature-symbol">✧</span>
        <blockquote class="signature-quote">
            "Cuisine is the emotion of the sea transformed into flavor, a ritual renewed every day under the Varcaturo sun."
        </blockquote>
        <p class="signature-author">— Our Philosophy</p>
    </section>

    <section class="content-section">
        <div class="content-image-wrapper reveal">
            <img src="../assets/images/about-home.webp" srcset="../assets/images/mobile-about-home.webp 800w, ../assets/images/about-home.webp 1200w" sizes="(max-width: 800px) 800px, 1200px" alt="Restaurant Playa Luna" class="content-image">
        </div>
        <div class="content-text reveal">
            <h2>A Seaside Lunch</h2>
            <p>Playa Luna Restaurant is open daily for lunch, all year round. Authentic Mediterranean cuisine where the daily catch takes center stage, served in a refined and elegant setting.</p>
            <div style="display:flex; gap:1.5rem;">
                <a href="https://wa.me/390001112233?text=I%20would%20like%20to%20reserve%20a%20table%20for%20lunch" class="btn-gold">Reserve Table</a>
                <a href="../assets/pdf/menu-ristorante.pdf" class="btn-gold" style="background:transparent; border:1px solid var(--gold); color:var(--gold);">View Menu</a>
            </div>
        </div>
    </section>

    <section class="cuisine-section reveal">
        <div class="cuisine-header">
            <span>Culinary Excellence</span>
            <h2>Our Cuisine</h2>
        </div>
        <div class="cuisine-grid">
            <div class="cuisine-card">
                <img src="../assets/images/piatto-crudo.webp" srcset="../assets/images/mobile-piatto-crudo.webp 800w, ../assets/images/piatto-crudo.webp 1200w" sizes="(max-width: 800px) 800px, 1200px" alt="Seafood Crudo" loading="lazy">
                <div class="cuisine-card-text">
                    <h3>Seafood Crudo</h3>
                    <p>Fresh raw fish and refined combinations to enhance the authentic flavor of the sea in every bite.</p>
                </div>
            </div>
            <div class="cuisine-card">
                <img src="../assets/images/piatto-pasta.webp" srcset="../assets/images/mobile-piatto-pasta.webp 800w, ../assets/images/piatto-pasta.webp 1200w" sizes="(max-width: 800px) 800px, 1200px" alt="Pasta Dish" loading="lazy">
                <div class="cuisine-card-text">
                    <h3>Tradition Redefined</h3>
                    <p>Fresh pasta dishes that combine classic Mediterranean ingredients with contemporary style and technique.</p>
                </div>
            </div>
        </div>
    </section>

    <section class="terrace-section reveal">
        <div class="terrace-content">
            <span>Seaside Elegance</span>
            <h2>The Terrace</h2>
            <p>The most exclusive area of our restaurant. A terrace overlooking the shore, where the sound of the waves accompanies every course, creating a magical and authentic atmosphere for your special moments.</p>
        </div>
        <img src="../assets/images/ristorante-terrazza-giorno.webp" srcset="../assets/images/mobile-ristorante-terrazza-giorno.webp 800w, ../assets/images/ristorante-terrazza-giorno.webp 1920w" sizes="(max-width: 800px) 800px, 1920px" alt="The Terrace Playa Luna" class="terrace-img reveal">
    </section>

    <div id="scrollTop">↑</div>

    <footer>
        <img src="../assets/logos/logo-playaluna.webp" alt="Playa Luna" style="height:100px; filter:brightness(0) invert(1);">
        <div class="footer-info">
            <p>Via Marina di Varcaturo, 42 - 81030 Castel Volturno (CE)</p>
            <p>LIDO PLAYALUNA SRL | VAT 09146931218</p>
            <p>Lunch: 12:30 - 16:30 | Evening: Private Events Only</p>
            <div style="margin-top: 2rem; display: flex; justify-content: center; gap: 2rem;">
                <a href="https://www.instagram.com/lidoplayaluna/" target="_blank" style="color: var(--white); text-decoration: none; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 2px;">@playalunaofficial</a>
                <a href="https://www.instagram.com/playalunaeventi/" target="_blank" style="color: var(--white); text-decoration: none; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 2px;">@playalunaeventi</a>
            </div>
        </div>
    </footer>

    <script src="../assets/js/global.js" defer></script>
    <script>


        window.addEventListener('scroll', () => {
            const navbar = document.getElementById('navbar');
            const stp = document.getElementById('scrollTop');
            if (window.scrollY > 50) navbar.classList.add('scrolled');
            else navbar.classList.remove('scrolled');

            if (window.scrollY > 500) stp.classList.add('visible');
            else stp.classList.remove('visible');
        });

        document.getElementById('scrollTop').onclick = () => window.scrollTo({top: 0, behavior: 'smooth'});

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => { if (entry.isIntersecting) entry.target.classList.add('visible'); });
        }, { threshold: 0.1 });
        document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
    </script>
</body>
</html>



