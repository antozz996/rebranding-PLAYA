<style>
        :root {
            --sand: #E0D4BB;
            --gold: #C9A84C;
            --off-white: #F9F7F2;
            --white: #FFFFFF;
            --text-dark: #1A1208;
            --text-light: #666059;
            --ease-out-expo: cubic-bezier(0.19, 1, 0.22, 1);
            --slide-padding: 8vw;
        }

        .decor-line { position: fixed; top: 0; width: 1px; height: 100vh; background: linear-gradient(to bottom, transparent, var(--gold), transparent); opacity: 0.1; z-index: 1002; pointer-events: none; }
        .line-left { left: 4vw; } .line-right { right: 4vw; }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { background-color: var(--off-white); color: var(--text-dark); font-family: 'Montserrat', sans-serif; overflow-x: hidden; line-height: 1.6; }
        h1, h2, h3, h4 { font-family: 'Playfair Display', serif; font-weight: 400; }

        .navbar {
            position: fixed; top: 0; left: 0; width: 100%;
            padding: 2rem var(--slide-padding);
            display: grid; grid-template-columns: 1fr auto 1fr;
            align-items: center; z-index: 1000;
            transition: all 0.5s var(--ease-out-expo);
        }
        .navbar.scrolled { background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(15px); padding: 1.2rem var(--slide-padding); }

        .nav-left { display: flex; justify-content: flex-start; gap: 2rem; list-style: none; }
        .nav-right { display: flex; justify-content: flex-end; gap: 2.5rem; list-style: none; align-items: center; }
        .nav-link { text-decoration: none; color: var(--text-dark); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 2px; transition: 0.3s; }
        .nav-link:hover { color: var(--gold); }

        .logo { height: 120px !important; width: auto !important; transition: 0.5s; }

        .hamburger { 
            display: none; 
            cursor: pointer; 
            z-index: 1100;
            background: rgba(255,255,255,0.1);
            border: 1px solid rgba(0,0,0,0.1);
            border-radius: 50%;
            padding: 10px;
            backdrop-filter: blur(10px);
        }
        .hamburger span { display: block; width: 25px; height: 2px; background: var(--text-dark); margin: 5px 0; transition: 0.4s; }

        @media (max-width: 1024px) {
            .navbar { padding: 1.2rem 5vw !important; display: flex !important; justify-content: space-between !important; align-items: center !important; grid-template-columns: unset !important; }
            .nav-left, .nav-right { display: none !important; }
            .hamburger {
                display: block !important;
                margin-left: auto;
                background: rgba(255,255,255,0.1) !important;
                border: 1px solid rgba(0,0,0,0.1) !important;
                border-radius: 50% !important;
                padding: 10px !important;
                backdrop-filter: blur(10px) !important;
            }
            .logo { height: 80px !important; }
            .contact-container { grid-template-columns: 1fr; padding: 0 5vw 6rem; }
            .contact-hero { padding: 8rem 5vw 4rem; }
            .contact-hero h1 { font-size: 2.8rem; }
            .contact-item-card { padding: 2rem; }
            .map-wrapper { min-height: 400px; }
            footer { padding: 4rem 5vw; }
        }

        .lang-switcher { font-size: 0.7rem; letter-spacing: 2px; text-transform: uppercase; margin-left: 1rem; }
        .lang-switcher a { text-decoration: none; color: var(--text-dark); opacity: 0.6; transition: 0.3s; }
        .lang-switcher a.active { opacity: 1; font-weight: 600; }

        .contact-hero { padding: 12rem var(--slide-padding) 6rem; text-align: center; background: var(--white); }
        .contact-hero h1 { font-size: 4.5rem; margin-bottom: 2rem; }

        .contact-container { 
            display: grid; 
            grid-template-columns: 1fr 1.2fr; 
            gap: 4vw; 
            padding: 0 var(--slide-padding) 10rem; 
            align-items: stretch; 
        }
        .contact-info-list { 
            display: flex; 
            flex-direction: column; 
            gap: 1.5rem; 
        }
        .contact-item-card { 
            background: var(--white); 
            padding: 3rem; 
            border: 1px solid rgba(0,0,0,0.05); 
            transition: 0.5s var(--ease-out-expo);
            display: flex;
            flex-direction: column;
            justify-content: center;
        }
        .contact-item-card:hover { border-color: var(--gold); transform: translateX(15px); }
        .contact-item-card h3 { font-size: 1.8rem; margin-bottom: 1rem; color: var(--gold); }
        .contact-item-card p { color: var(--text-light); margin-bottom: 2rem; }

        .map-wrapper { 
            height: 100%; 
            min-height: 600px; 
            position: relative; 
            filter: grayscale(1) contrast(1.2); 
            opacity: 0.8; 
            transition: 0.5s; 
            border: 1px solid rgba(0,0,0,0.05);
        }
        .map-wrapper:hover { filter: none; opacity: 1; }

        .reveal { opacity: 0; transform: translateY(30px); transition: 1.2s var(--ease-out-expo); }
        .reveal.visible { opacity: 1; transform: translateY(0); }

        footer { background: var(--text-dark); color: var(--white); padding: 8rem var(--slide-padding); text-align: center; }

        .btn-wa {
            display: inline-flex; align-items: center; gap: 1rem;
            padding: 1rem 2rem; background: #25d366; color: var(--white);
            text-decoration: none; border-radius: 50px; font-weight: 600;
            transition: 0.3s;
        }
        .btn-wa:hover { transform: scale(1.05); box-shadow: 0 10px 30px rgba(37,211,102,0.3); }

        @media (max-width: 1024px) {
            .contact-container { grid-template-columns: 1fr; }
            .map-wrapper { min-height: 450px; }
            .contact-hero h1 { font-size: 3rem; }
        }
    </style>
<!-- Schema.org / LocalBusiness -->
